# Copy this file to ".env" and fill your own values.
# Do not commit real secrets.

# -------- LLM --------
ZHIPU_API_KEY=your_zhipu_api_key
ZHIPU_MODEL=glm-4.5-flash

# -------- XF RTASR (Option A: single config) --------
XF_APPID=your_xf_appid
XF_API_KEY=your_xf_api_key
XF_API_SECRET=your_xf_api_secret

# -------- XF RTASR (Option B: multiple configs as JSON) --------
# XF_API_CONFIGS_JSON=[{"APPID":"xxx","APIKey":"xxx","APISecret":"xxx"}]

# -------- Optional path overrides --------
# VOSK_MODEL_PATH=models/vosk-model-cn-0.22
# EMBEDDING_MODEL_PATH=models/embedding/BAAI/bge-large-zh-v1___5
# FAISS_INDEX_PATH=data/faiss_data/faiss_index.index
# FAISS_DATA_PATH=data/faiss_data/faiss_data.json
# FAISS_KEYWORD_PATH=data/faiss_data/my_keywords.json
# AUDIO_HELLO_PATH=assets/audio/hello.mp3
# FRAME_DIR_IDLE=assets/animations/idle/0
# HTML_PATH=web/heritage/templates/index.html
